#!/usr/bin/env bash
# bin/audit — single-command pre-push verification for the seams gem.
#
# Runs every deterministic check in order, fails fast (`set -e`), and
# prints a clear pass/fail line per step. Pre-push git hook calls this;
# CI runs the same checks via parallel jobs.
#
# Usage:
#   bin/audit            # all checks
#   bin/audit --fast     # skip the ~30s integration suite
#
# Exit non-zero on any failure.

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

FAST=0
for arg in "$@"; do
  case "$arg" in
    --fast|-f) FAST=1 ;;
    *)         echo "unknown arg: $arg"; exit 2 ;;
  esac
done

heading() { printf "\n\033[1;34m== %s ==\033[0m\n" "$1"; }
pass()    { printf "\033[1;32mOK\033[0m %s\n" "$1"; }

heading "rubocop --parallel"
bundle exec rubocop --parallel
pass "rubocop"

heading "rspec (default suite)"
bundle exec rspec
pass "rspec default"

heading "bundle-audit (vulnerable gems)"
bundle exec bundle-audit check --update
pass "bundle-audit"

# Brakeman runs against the gem itself as a sanity check. The gem doesn't
# have a Rails app surface — `--force` makes brakeman scan as a generic
# Ruby project.
heading "brakeman (--force, gem source)"
bundle exec brakeman --force --no-pager --no-progress --quiet
pass "brakeman"

heading "Publisher orphan-subscriptions check"
bundle exec ruby -e '
require "seams"
require "seams/events/publisher"
require "seams/event_registry"
orphans = Seams::Events::Publisher.orphan_subscriptions
abort "orphan subscriptions: #{orphans}" unless orphans.empty?
puts "no orphan subscriptions"
'
pass "publisher contract"

if [ "$FAST" -eq 0 ]; then
  heading "rspec integration_full (rails new + Postgres + 5 engines)"
  bundle exec rspec spec/integration_full/ --tag type:integration_full
  pass "rspec integration_full"
else
  printf "\033[1;33mSKIPPED\033[0m rspec integration_full (--fast)\n"
fi

printf "\n\033[1;32mAll audit checks passed.\033[0m\n"
