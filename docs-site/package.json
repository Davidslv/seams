{
  "name": "seams-docs-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Astro Starlight documentation site for the Seams gem. Content is synced from ../doc and ../README.md at build time (no file moves).",
  "scripts": {
